{
  "name": "tailwind-nextjs-starter-blog",
  "version": "1.1.3",
  "private": true,
  "scripts": {
    "start": "next-remote-watch ./data",
    "dev": "next dev",
    "build": "next build && node ./scripts/generate-sitemap",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir components --dir lib --dir layouts --dir scripts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@mailchimp/mailchimp_marketing": "3.0.72",
    "@plaiceholder/next": "2.2.0",
    "@tailwindcss/forms": "0.3.4",
    "@tailwindcss/typography": "0.4.1",
    "autoprefixer": "10.4.0",
    "esbuild": "0.13.14",
    "github-slugger": "1.4.0",
    "gray-matter": "4.0.3",
    "image-size": "1.0.0",
    "mdx-bundler": "8.0.0",
    "next": "12.0.4",
    "next-themes": "0.0.15",
    "plaiceholder": "2.2.0",
    "postcss": "8.3.11",
    "preact": "10.5.15",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-lines-ellipsis": "0.15.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "6.1.0",
    "rehype-katex": "6.0.2",
    "rehype-prism-plus": "1.1.2",
    "rehype-slug": "5.0.0",
    "remark-footnotes": "4.0.1",
    "remark-gfm": "3.0.1",
    "remark-math": "5.1.1",
    "sharp": "0.29.3",
    "tailwindcss": "2.2.19",
    "twemoji": "13.1.0",
    "unist-util-visit": "4.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "12.0.4",
    "@svgr/webpack": "5.5.0",
    "@types/react": "17.0.35",
    "@types/tailwindcss": "2.2.4",
    "@typescript-eslint/eslint-plugin": "5.4.0",
    "@typescript-eslint/parser": "5.4.0",
    "cross-env": "7.0.3",
    "dedent": "0.7.0",
    "eslint": "7.32.0",
    "eslint-config-next": "12.0.4",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-prettier": "4.0.0",
    "file-loader": "6.2.0",
    "globby": "11.0.4",
    "husky": "7.0.4",
    "inquirer": "8.2.0",
    "lint-staged": "12.0.2",
    "next-remote-watch": "1.0.0",
    "prettier": "2.4.1",
    "typescript": "4.5.2"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
